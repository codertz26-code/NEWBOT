// autoreply.js
const config = require('./config');
const axios = require('axios');

// Chatbot function using API
async function getChatbotResponse(text) {
    try {
        const response = await axios.get(`https://api.yupra.my.id/api/ai/gpt5?text=${encodeURIComponent(text)}`);
        return response.data.result || response.data.response || "𝙷𝚊𝚙𝚊𝚗𝚒, 𝚜𝚒𝚓𝚊𝚎𝚕𝚎𝚟𝚊 𝚔𝚞𝚓𝚒𝚋𝚞...";
    } catch (error) {
        console.error('Chatbot error:', error);
        return null;
    }
}

// Check if message is command
function isCommand(text) {
    return text && (text.startsWith('.') || text.startsWith('!') || text.startsWith('/'));
}

// Process auto reply for messages
async function processAutoReply(zk, mek, messageText, isGroup, sender) {
    if (!messageText || typeof messageText !== 'string') return false;
    
    const lowerText = messageText.toLowerCase().trim();
    
    // Skip if it's a command
    if (isCommand(messageText)) return false;
    
    // Check if autoreply is enabled for the context
    if (isGroup && !config.features.autoreplyGrp) return false;
    if (!isGroup && !config.features.autoreplyDm) return false;
    
    // Try exact match first
    if (config.autoReplies[lowerText]) {
        await zk.sendMessage(mek.key.remoteJid, {
            text: config.autoReplies[lowerText],
            contextInfo: {
                mentionedJid: [sender],
                forwardingScore: 999,
                isForwarded: true,
                forwardedNewsletterMessageInfo: {
                    newsletterJid: config.channelJid,
                    newsletterName: '© 𝐒𝐈𝐋𝐀 𝐓𝐄𝐂𝐇',
                    serverMessageId: 143
                }
            }
        }, { quoted: mek });
        return true;
    }
    
    // Try partial match for longer messages
    for (const [key, value] of Object.entries(config.autoReplies)) {
        if (lowerText.includes(key) && key.length > 2) {
            await zk.sendMessage(mek.key.remoteJid, {
                text: value,
                contextInfo: {
                    mentionedJid: [sender],
                    forwardingScore: 999,
                    isForwarded: true,
                    forwardedNewsletterMessageInfo: {
                        newsletterJid: config.channelJid,
                        newsletterName: '© 𝐒𝐈𝐋𝐀 𝐓𝐄𝐂𝐇',
                        serverMessageId: 143
                    }
                }
            }, { quoted: mek });
            return true;
        }
    }
    
    // Use chatbot if enabled and no auto reply matched
    if (config.features.chatbot && lowerText.length > 3) {
        const botResponse = await getChatbotResponse(lowerText);
        if (botResponse) {
            await zk.sendMessage(mek.key.remoteJid, {
                text: botResponse,
                contextInfo: {
                    mentionedJid: [sender],
                    forwardingScore: 999,
                    isForwarded: true,
                    forwardedNewsletterMessageInfo: {
                        newsletterJid: config.channelJid,
                        newsletterName: '© 𝐒𝐈𝐋𝐀 𝐓𝐄𝐂𝐇',
                        serverMessageId: 143
                    }
                }
            }, { quoted: mek });
            return true;
        }
    }
    
    return false;
}

module.exports = {
    processAutoReply,
    getChatbotResponse
};
