const { sila, fkontak } = require('../silamd/sila');
const { downloadContentFromMessage } = require('@whiskeysockets/baileys');
const config = require('../config');

sila({
    nomCom: 'viewonce',
    alias: ['viewonce', 'readonce', 'vo'],
    react: '👁️',
    desc: 'View view-once messages',
    Categorie: 'Owner',
    fromMe: 'true'
},
async (dest, zk, mek, { from, q, sender, reply }) => {
    if (!mek.message?.extendedTextMessage?.contextInfo?.quotedMessage) {
        return reply(`❌ 𝙿𝚕𝚎𝚊𝚜𝚎 𝚛𝚎𝚙𝚕𝚢 𝚝𝚘 𝚊 𝚟𝚒𝚎𝚠-𝚘𝚗𝚌𝚎 𝚖𝚎𝚜𝚜𝚊𝚐𝚎`);
    }

    const quoted = mek.message.extendedTextMessage.contextInfo.quotedMessage;
    const viewOnceMsg = quoted.viewOnceMessage || quoted.viewOnceMessageV2;
    
    if (!viewOnceMsg) {
        return reply(`❌ 𝚃𝚑𝚒𝚜 𝚒𝚜 𝚗𝚘𝚝 𝚊 𝚟𝚒𝚎𝚠-𝚘𝚗𝚌𝚎 𝚖𝚎𝚜𝚜𝚊𝚐𝚎`);
    }

    try {
        const mediaType = Object.keys(viewOnceMsg)[0];
        const stream = await downloadContentFromMessage(viewOnceMsg[mediaType], mediaType);
        const buffer = [];
        for await (const chunk of stream) {
            buffer.push(chunk);
        }
        const mediaBuffer = Buffer.concat(buffer);

        await zk.sendMessage(from, {
            [mediaType]: mediaBuffer,
            caption: `👁️ 𝚅𝚒𝚎𝚠 𝙾𝚗𝚌𝚎 𝙼𝚎𝚜𝚜𝚊𝚐𝚎\n\n> © 𝙿𝚘𝚠𝚎𝚛𝚎𝚍 𝚋𝚢 ${config.botName}`
        }, { quoted: fkontak });

    } catch (e) {
        reply(`❌ 𝙴𝚛𝚛𝚘𝚛: ${e.message}`);
    }
});
```

