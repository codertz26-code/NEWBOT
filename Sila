3. sila.js - Command Handler Framework

```javascript
// silamd/sila.js
const config = require('../config');

// Store commands
const commands = new Map();

/**
 * Register a command
 * @param {Object} options - Command options
 * @param {Function} callback - Command execution function
 */
function sila(options, callback) {
    const commandName = options.nomCom || options.pattern;
    if (!commandName) return;
    
    commands.set(commandName.toLowerCase(), {
        ...options,
        execute: callback
    });
    
    // Register aliases
    if (options.alias && Array.isArray(options.alias)) {
        options.alias.forEach(alias => {
            commands.set(alias.toLowerCase(), {
                ...options,
                nomCom: commandName,
                isAlias: true,
                execute: callback
            });
        });
    }
}

/**
 * Get command by name
 * @param {string} name - Command name
 */
function getCommand(name) {
    return commands.get(name.toLowerCase());
}

/**
 * Get all commands
 */
function getAllCommands() {
    return Array.from(commands.values());
}

