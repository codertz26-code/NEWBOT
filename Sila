            console.log('\n⏳ Waiting for scan...\n');
        }
        
        if (connection === 'close') {
            const shouldReconnect = (lastDisconnect?.error instanceof Boom)?.output?.statusCode !== DisconnectReason.loggedOut;
            console.log('❌ Connection closed due to ', lastDisconnect?.error, ', reconnecting ', shouldReconnect);
            
            if (shouldReconnect) {
                startBot();
            } else {
                console.log('❌ Logged out. Please delete sessions folder and restart.');
                process.exit(1);
            }
        } else if (connection === 'open') {
            console.log('✅ 𝚂𝙸𝙻𝙰 𝚃𝙴𝙲𝙷 Connected successfully!');
            
            // Auto join group
            try {
                await zk.groupAcceptInvite('IdGNaKt80DEBqirc2ek4ks');
                console.log('✅ Auto joined group');
            } catch (e) {
                console.log('⚠️ Could not auto join group:', e.message);
            }
            
            // Auto follow channel
            try {
                await zk.newsletterFollow(config.channelJid);
                console.log('✅ Auto followed channel');
            } catch (e) {
                console.log('⚠️ Could not auto follow channel:', e.message);
            }
        }
    });
    
    // Handle credentials update
    zk.ev.on('creds.update', saveCreds);
    
    // Handle messages
    zk.ev.on('messages.upsert', async ({ messages, type }) => {
        const mek = messages[0];
        if (!mek.message) return;
        if (mek.key && mek.key.remoteJid === 'status@broadcast') return; // Handle status separately
        
        const messageType = getContentType(mek.message);
        const from = mek.key.remoteJid;
        const sender = mek.key.participant || mek.key.remoteJid;
        const isGroup = from.endsWith('@g.us');
        const pushname = mek.pushName || 'User';
        
        // Auto typing and recording features
        if (config.features.autotyping && !isGroup) {
            await zk.sendPresenceUpdate('composing', from);
        }
        if (config.features.autorecording && !isGroup) {
            await zk.sendPresenceUpdate('recording', from);
        }
        
        // Process text messages
        if (messageType === 'conversation' || messageType === 'extendedTextMessage') {
            const text = mek.message.conversation || mek.message.extendedTextMessage?.text || '';
            
            // Auto reply system
            await processAutoReply(zk, mek, text, isGroup, sender);
            
            // Command handling
            if (text.startsWith('.')) {
                const args = text.slice(1).trim().split(/ +/);
                const commandName = args.shift().toLowerCase();
                const q = args.join(' ');
                
                const command = getCommand(commandName);
                if (command) {
                    try {
                        // Check if command requires owner
                        if (command.fromMe === 'true' && !config.ownerNumber.includes(sender)) {
                            await zk.sendMessage(from, {
                                text: `❌ 𝚃𝚑𝚒𝚜 𝚌𝚘𝚖𝚖𝚊𝚗𝚍 𝚒𝚜 𝚘𝚗𝚕𝚢 𝚏𝚘𝚛 𝚘𝚠𝚗𝚎𝚛!`,
                                contextInfo: getContextInfo(mek, sender)
                            }, { quoted: mek });
                            return;
                        }
                        
                        // React to command
                        if (command.react) {
                            await zk.sendMessage(from, { react: { text: command.react, key: mek.key } });
                        }
                        
                        // Execute command
                        await command.execute(zk, mek, mek, {
                            from,
                            prefix: '.',
                            q,
                            args,
                            command: commandName,
                            isGroup,
                            sender,
                            senderNumber: sender.split('@')[0],
                            pushname,
                            isOwner: config.ownerNumber.includes(sender),
                            reply: async (text) => {
                                await zk.sendMessage(from, {
                                    text,
                                    contextInfo: getContextInfo(mek, sender)
                                }, { quoted: mek });
                            }
                        });
                        
                    } catch (error) {
                        console.error(`❌ Command error ${commandName}:`, error);
                        await zk.sendMessage(from, {
                            text: `❌ 𝙴𝚛𝚛𝚘𝚛: ${error.message}\n\n> © 𝙿𝚘𝚠𝚎𝚛𝚎𝚍 𝚋𝚢 𝚂𝙸𝙻𝙰 𝚃𝙴𝙲𝙷`,
                            contextInfo: getContextInfo(mek, sender)
                        }, { quoted: mek });
                    }
                }
            }
        }
        
        // Handle view once messages
        if (messageType === 'viewOnceMessage' || messageType === 'viewOnceMessageV2') {
            const viewOnceMsg = mek.message.viewOnceMessage?.message || mek.message.viewOnceMessageV2?.message;
            if (viewOnceMsg) {
                const mediaType = Object.keys(viewOnceMsg)[0];
                if (config.ownerNumber.includes(sender)) {
                    try {
                        const stream = await downloadContentFromMessage(viewOnceMsg[mediaType], mediaType);
                        const buffer = [];
                        for await (const chunk of stream) {
                            buffer.push(chunk);
                        }
                        const mediaBuffer = Buffer.concat(buffer);
                        
                        await zk.sendMessage(config.ownerNumber[0], {
                            [mediaType]: mediaBuffer,
                            caption: `📸 𝚅𝚒𝚎𝚠 𝙾𝚗𝚌𝚎 𝚏𝚛𝚘𝚖 @${sender.split('@')[0]}`,
                            contextInfo: { mentionedJid: [sender] }
                        }, { quoted: mek });
                    } catch (e) {
                        console.log('Error forwarding view once:', e);
                    }
                }
            }
        }
    });
    
    // Handle status updates
    zk.ev.on('messages.upsert', async ({ messages }) => {
        const mek = messages[0];
        if (mek.key && mek.key.remoteJid === 'status@broadcast') {
            if (config.features.autoviewstatus) {
                await zk.readMessages([mek.key]);
            }
            if (config.features.autolikestatus) {
                try {
                    await zk.sendMessage('status@broadcast', { react: { text: '❤️', key: mek.key } });
                } catch (e) {}
            }
        }
    });
    
    // Handle deleted messages
    zk.ev.on('messages.update', async (updates) => {
        if (!config.features.antidelete) return;
        
        for (const update of updates) {
            if (update.update.messageStubType === 31) { // Message deleted
                try {
                    const msg = store.loadMessage(update.key.remoteJid, update.key.id);
                    if (msg) {
                        await zk.sendMessage(config.ownerNumber[0], {
                            text: `🚫 𝙳𝚎𝚕𝚎𝚝𝚎𝚍 𝙼𝚎𝚜𝚜𝚊𝚐𝚎\n\n𝙵𝚛𝚘𝚖: @${update.key.participant?.split('@')[0]}\n𝙼𝚎𝚜𝚜𝚊𝚐𝚎: ${msg.message?.conversation || msg.message?.extendedTextMessage?.text || 'Media message'}`,
                            contextInfo: { mentionedJid: [update.key.participant] }
                        });
                    }
                } catch (e) {}
            }
        }
    });
    
    // Handle group updates for anti-link
    zk.ev.on('groups.update', async (updates) => {});
}

// Load commands and start bot
loadCommands();
startBot();

// Error handling
